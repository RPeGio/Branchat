{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Branchat",
  "version": "0.1.0",
  "identifier": "com.tauri-app.Branchat",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Branchat",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/favicon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
